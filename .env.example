# ─────────────────────────────────────────────────────────────
# LMP — Portail de Suivi Éditorial — Environment variables
# Copy to .env  (Prisma reads .env) — and .env.local for Next.js dev.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME="LMP — Portail de Suivi Éditorial"
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# Database (PostgreSQL)
# ── Supabase (PROD / Vercel) ───────────────────────────────────────────────
#   DATABASE_URL : connexion POOLÉE (Supavisor, port 6543) — runtime serverless
#   DIRECT_URL   : connexion DIRECTE (port 5432)          — migrations Prisma
#   Récupérer dans Supabase → Project Settings → Database → Connection string.
# DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
#
# ── Local / Docker (dev) ───────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lmp?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/lmp?schema=public"

# Auth (custom JWT session — HS256). Generate a strong secret:
#   openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Email notifications — Resend (https://resend.com).
# Leave RESEND_API_KEY empty in dev to log emails to the console.
# Récupérer la clé dans Resend → API Keys. EMAIL_FROM doit utiliser un
# domaine vérifié dans Resend (sinon onboarding@resend.dev pour les tests).
RESEND_API_KEY=""
EMAIL_FROM="LMP <onboarding@resend.dev>"

# File storage — Supabase Storage (téléversement réel des documents/images).
# Tant que ces variables sont vides, les formulaires basculent automatiquement
# sur un champ « lien » (pas de blocage).
#   SUPABASE_URL              : https://<ref>.supabase.co  (Project Settings → API → Project URL)
#   SUPABASE_SERVICE_ROLE_KEY : clé service_role           (Project Settings → API → service_role) — SECRÈTE, serveur uniquement
#   SUPABASE_STORAGE_BUCKET   : nom du bucket (défaut "lmp-files") — à créer dans Supabase → Storage, en PUBLIC
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="lmp-files"
