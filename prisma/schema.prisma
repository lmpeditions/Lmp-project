// ─────────────────────────────────────────────────────────────────────────
// LMP — Portail de Suivi Éditorial — Prisma schema
// PostgreSQL (Docker locally, or Supabase). Run:
//   npm run db:generate && npm run db:migrate && npm run db:seed
// ─────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ------------------------------- Enums -----------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  AUTHOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum ThemePref {
  LIGHT
  DARK
  SYSTEM
}

enum Locale {
  FR
  EN
}

enum DossierStatus {
  PENDING_VALIDATION
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum StageType {
  CONTRAT
  ISBN
  RELECTURE
  CORRECTION
  COUVERTURE
  MISE_EN_PAGE
  COMMUNICATION
  PUBLICATION
}

enum StageStatus {
  DONE
  IN_PROGRESS
  UPCOMING
  PENDING
}

enum PaymentMethod {
  TRANSFER
  CASH
  CARD
}

enum PaymentStatus {
  VALIDATED
  PENDING
}

enum TicketCategory {
  GENERAL
  COMPLAINT
  FINANCE
  PROOFREADING
  COVER
  COMMUNICATION
  TECHNICAL
  TERMINATION
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum DocumentCategory {
  MANUSCRIPT
  ADMINISTRATIVE
  VISUALS
  COVER
  CONTENT
  FINANCIAL
  COMMUNICATION
}

enum NotificationType {
  STAGE
  DOCUMENT
  TICKET
  PAYMENT
  VALIDATION
  TERMINATION
}

enum TerminationStatus {
  NOT_STARTED
  SUBMITTED
  REVIEW
  DECISION
  CLOSED
}

// ------------------------------- Models -----------------------------------

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?
  name         String
  phone        String?
  address      String?
  nationality  String?
  cin          String?
  profession   String?
  role         Role       @default(AUTHOR)
  status       UserStatus @default(INVITED)
  locale       Locale     @default(FR)
  theme        ThemePref  @default(SYSTEM)
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastActiveAt DateTime?

  // An author owns dossiers; a manager is assigned to dossiers.
  ownedDossiers    Dossier[]      @relation("DossierAuthor")
  managedDossiers  Dossier[]      @relation("DossierManager")
  ticketsCreated   Ticket[]       @relation("TicketAuthor")
  ticketsAssigned  Ticket[]       @relation("TicketAssignee")
  ticketMessages   TicketMessage[]
  uploadedDocuments Document[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  inviteTokens     InviteToken[]

  @@index([role])
  @@index([status])
}

// Secure single-use token for author onboarding & password reset.
model InviteToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   String   @default("ACTIVATION") // ACTIVATION | PASSWORD_RESET
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Dossier {
  id                   String        @id @default(cuid())
  trackingNumber       String        @unique // e.g. #LMP20260001
  bookTitle            String
  description          String?
  formula              String
  status               DossierStatus @default(IN_PROGRESS)
  globalProgress       Int           @default(0)
  contractTotal        Int           @default(0) // amount in DH
  startDate            DateTime
  estimatedPublication DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  authorId String
  author   User   @relation("DossierAuthor", fields: [authorId], references: [id])

  managerId String?
  manager   User?   @relation("DossierManager", fields: [managerId], references: [id])

  stages           Stage[]
  payments         Payment[]
  schedules        PaymentSchedule[]
  documents        Document[]
  tickets          Ticket[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  termination      TerminationRequest?

  @@index([authorId])
  @@index([managerId])
  @@index([status])
}

model Stage {
  id        String      @id @default(cuid())
  dossierId String
  dossier   Dossier     @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  type      StageType
  status    StageStatus @default(UPCOMING)
  progress  Int         @default(0)
  notes     String?
  // Per-stage sub-steps (e.g. correction: spelling/grammar/style/validation).
  substeps  Json?
  order      Int        @default(0)
  updatedAt DateTime    @updatedAt

  @@unique([dossierId, type])
  @@index([dossierId])
}

model Payment {
  id        String        @id @default(cuid())
  dossierId String
  dossier   Dossier       @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  date      DateTime
  amount    Int
  method    PaymentMethod
  reference String
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())

  @@index([dossierId])
}

model PaymentSchedule {
  id        String   @id @default(cuid())
  dossierId String
  dossier   Dossier  @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  dueDate   DateTime
  amount    Int
  paid      Boolean  @default(false)

  @@index([dossierId])
}

model Document {
  id           String           @id @default(cuid())
  dossierId    String
  dossier      Dossier          @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  name         String
  category     DocumentCategory
  mimeType     String
  sizeLabel    String
  url          String
  version      Int              @default(1)
  comment      String?
  uploadedById String?
  uploadedBy   User?            @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime         @default(now())

  @@index([dossierId])
  @@index([category])
}

model Ticket {
  id         String         @id @default(cuid())
  ref        String         @unique // e.g. TIC-014
  dossierId  String
  dossier    Dossier        @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  subject    String
  category   TicketCategory
  status     TicketStatus   @default(OPEN)
  authorId   String
  author     User           @relation("TicketAuthor", fields: [authorId], references: [id])
  assigneeId String?
  assignee   User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  messages TicketMessage[]

  @@index([dossierId])
  @@index([status])
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation(fields: [senderId], references: [id])
  body        String
  attachments Json? // string[] of file URLs
  createdAt   DateTime @default(now())

  @@index([ticketId])
}

model TerminationRequest {
  id        String            @id @default(cuid())
  dossierId String            @unique
  dossier   Dossier           @relation(fields: [dossierId], references: [id], onDelete: Cascade)
  status    TerminationStatus @default(SUBMITTED)
  reason    String?
  steps     Json? // [{ key, done }]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  dossierId String?
  dossier   Dossier?         @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([read])
}

// Audit trail — who did what, when (OWASP logging requirement).
model ActivityLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  dossierId String?
  dossier   Dossier? @relation(fields: [dossierId], references: [id], onDelete: SetNull)
  action    String // e.g. "stage.updated", "payment.validated"
  entity    String // e.g. "Dossier", "Payment"
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([dossierId])
  @@index([actorId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
